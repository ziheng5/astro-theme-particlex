---
import type { BlogPost } from "../lib/posts";
import { excerpt, formatDate, slugify, tagColor } from "../lib/posts";
import { withBase } from "../lib/url";

const { post } = Astro.props as { post: BlogPost };
const category = post.categories[0];
---

<article class="post">
  <a href={withBase(post.path)}>
    <h2 class="post-title">{post.title}</h2>
  </a>

  <div class="category-and-date">
    {category && (
      <span class="category">
        <a href={withBase(`/categories/${slugify(category)}/`)}>
          <span class="icon"><i class="fa-solid fa-bookmark fa-fw"></i></span>
          {category}
        </a>
      </span>
    )}

    <span class="date">
      <span class="icon"><i class="fa-solid fa-calendar fa-fw"></i></span>
      {formatDate(post.date)}
    </span>

    {post.pinned > 0 && (
      <span class="special">
        <i class="fa-solid fa-grip-vertical fa-fw"></i>
      </span>
    )}
  </div>

  {excerpt(post) && (
    <div class="description">
      <div class="content">
        <p>{excerpt(post)}</p>
      </div>
    </div>
  )}

  <div class="post-tags">
    {post.tags.length > 0 && (
      <span class="icon">
        <i class="fa-solid fa-tags fa-fw"></i>
      </span>
    )}

    {post.tags.map((tag, index) => (
      <span class="tag">
        <a href={withBase(`/tags/${slugify(tag)}/`)} style={`color: ${tagColor(index)}`}>
          {tag}
        </a>
      </span>
    ))}
  </div>

  <a href={withBase(post.path)} class="go-post">阅读全文</a>
</article>
